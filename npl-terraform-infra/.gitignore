# ---------------------------------------------------------------------------
# Terraform .gitignore (HashiCorp / github/gitignore standard)
# ---------------------------------------------------------------------------

# Local .terraform directories
**/.terraform/*

# .tfstate files (contain full resource state — never commit)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude .tfvars files by default — they are likely to contain sensitive data
# such as passwords or provider secrets. staging.tfvars is committed
# intentionally (no secrets: just account-id/domain values used by CI).
*.tfvars
*.tfvars.json
!staging.tfvars

# Ignore override files, used for local overrides
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Saved plan output
*tfplan*

# CLI configuration files
.terraformrc
terraform.rc

# NOTE: .terraform.lock.hcl is intentionally NOT ignored — it pins provider
# versions and SHOULD be committed.

# Claude Code local/personal settings (not shared)
.claude/settings.local.json
